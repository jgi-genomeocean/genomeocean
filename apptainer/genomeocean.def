Bootstrap: docker
From: nvcr.io/nvidia/vllm:25.09-py3

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export CUDA_HOME="/usr/local/cuda"
    export VLLM_WORKER_MULTIPROC_METHOD=spawn
    export VLLM_USE_V1=0
    export HF_HOME="/workspace/model_cache"
    export TMPDIR="/workspace/tmp"
    export LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"
    export PATH="/home/vllm/.local/bin:$PATH"

%post
    export DEBIAN_FRONTEND=noninteractive
    
    # Create directories
    mkdir -p /workspace/model_cache /workspace/tmp /workspace/build_temp
    export TMPDIR="/workspace/build_temp"

    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        wget git curl bzip2 libx11-6 build-essential \
        && apt-get clean && rm -rf /var/lib/apt/lists/*
    
    # Install uv
    pip install uv --break-system-packages

    # Install Python dependencies using uv (inheriting from base image's python)
    # We use --system because we want to install into the container's main python environment
    # mimicking the Dockerfile behavior
    uv pip install --system --no-cache-dir peft accelerate bitsandbytes pandas biopython scikit-learn pyrodigal \
        cloudpickle msgspec outlines sentencepiece pydantic ray psutil

    # Install the package from local source (copied in %files)
    cd /genomeocean
    uv pip install --system --no-deps -e .

    # Clean up
    rm -rf /workspace/build_temp

%files
    # Copy all files from current directory to /genomeocean in container
    . /genomeocean

%runscript
    # Default entry point: the unified GenomeOcean inference CLI.
    # Usage: apptainer run genomeocean.sif generate --model_dir pGenomeOcean/GenomeOcean-4B ...
    # For an interactive shell: apptainer shell --nv genomeocean.sif
    if [ "$#" -eq 0 ]; then
        exec go-infer --help
    else
        exec go-infer "$@"
    fi

%labels
    Maintainer Zhong Wang